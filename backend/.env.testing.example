# ── Testing / Sandbox Environment ──
# Copy to .env on the sandbox server: cp .env.testing.example .env

# App Database (read-write, for users/roles/permissions/config)
# Overridden by docker-compose environment section — this is a fallback
APP_DATABASE_URL=postgresql+asyncpg://rt_user:rt_password@app-db:5432/rt_reporting

# Odoo Read Replica (read-only)
ODOO_DATABASE_URL=postgresql+asyncpg://odoo_reader:password@your-aws-replica-host:5432/odoo_db

# JWT — generate a unique key for this environment
JWT_SECRET_KEY=change-this-to-a-unique-testing-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Google SSO
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://sandbox.reporting.refreshedtech.com/api/auth/google/callback
ALLOWED_DOMAIN=refreshedtech.com

# VAPID Keys (for Web Push notifications)
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_CLAIM_EMAIL=mailto:admin@refreshedtech.com

# SMTP (for email reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=reports@refreshedtech.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=RT Reporting (Sandbox)
SMTP_FROM_EMAIL=reports@refreshedtech.com

# Business timezone (for converting UTC dates in reports)
BUSINESS_TIMEZONE=America/New_York

# Budget KPI mapping (JSON object mapping Odoo budget post names to KPI keys)
BUDGET_KPI_MAPPING={}

# Frontend URL (for CORS and redirects)
FRONTEND_URL=https://sandbox.reporting.refreshedtech.com
